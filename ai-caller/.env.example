# ── Server Configuration ────────────────────────────
PORT=3001

# ── Gemini ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── ElevenLabs ───────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Go to elevenlabs.io → Voices → pick one → copy its ID
ELEVENLABS_VOICE_ID=your_voice_id_here
ELEVENLABS_VOICE_EN=your_english_voice_id_here
ELEVENLABS_VOICE_HI=your_hindi_voice_id_here
ELEVENLABS_VOICE_MR=your_marathi_voice_id_here

# ── Seminar Details (edit these!) ────────────────────
SEMINAR_NAME=MHT CET 2026 Preparation & Guidance Seminar
SEMINAR_DATE=Coming Soon - 2026
SEMINAR_TOPIC=MHT-CET Physics, Chemistry & Mathematics Mastery
SEMINAR_VENUE=Online / Zoom
SEMINAR_LINK=https://your-registration-link.com

# ── CSV ──────────────────────────────────────────────
CSV_FILE=contacts.csv
PHONE_COLUMN=phone        # exact column header name in your CSV

# ── Output ───────────────────────────────────────────
RESULTS_FILE=results.csv

# ── TWILIO CREDENTIALS (Voice & WhatsApp) ────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── EXOTEL CREDENTIALS (REAL CALLING) ────────────────
# Sign up at https://my.exotel.com and add your credentials here
EXOTEL_SID=your_exotel_account_sid
EXOTEL_TOKEN=your_exotel_auth_token
EXOTEL_FROM_NUMBER=your_exotel_phone_number

# ── BASE URL (for webhooks) ──────────────────────────
# For local testing, use ngrok: https://ngrok.com/
BASE_URL=http://localhost:3001

# ── WhatsApp Configuration ────────────────────────────
WHATSAPP_REGISTRATION_LINK=https://campusdekho.ai/mht-cet-registration
