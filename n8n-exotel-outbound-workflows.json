      "parameters": {
        "responseBody": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Response>\n  <Say voice=\"woman\">Thank you for your time. Goodbye!</Say>\n  <Hangup/>\n</Response>",
        "options": {
