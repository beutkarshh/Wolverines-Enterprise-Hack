        "functionCode": "const url = $json.data?.url || '';\nconst playable = url.replace('tmpfiles.org/', 'tmpfiles.org/dl/');\nconst twiml = '<?xml version=\"1.0\" encoding=\"UTF-8\"?>\\n<Response>\\n  <Play>' + playable + '</Play>\\n  <Gather timeout=\"6\" numDigits=\"1\" action=\"https://synthomind.cloud/webhook/exotel-gather\" method=\"POST\">\\n    <Say voice=\"woman\">Press 1 for yes, 2 for no, or speak your response.</Say>\\n  </Gather>\\n  <Redirect method=\"POST\">https://synthomind.cloud/webhook/exotel-timeout</Redirect>\\n</Response>';\nreturn [{ twiml }];"
      }
