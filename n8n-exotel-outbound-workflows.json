        "sendBody": true,
        "jsonParameters": true,
        "responseFormat": "file",
        "bodyParametersJson": "{\"text\":\"{{$json.text}}\",\"model_id\":\"eleven_multilingual_v2\",\"voice_settings\":{\"stability\":0.35,\"similarity_boost\":0.8,\"style\":0.45,\"use_speaker_boost\":true}}",
        "headerParameters": [
